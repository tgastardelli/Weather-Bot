# Runtime
MODE=paper
DB_URL=sqlite+aiosqlite:///./data/bot.db
COLLECTORS_ENABLED=true

# Automated paper validation universe.
CITIES=["seoul","tokyo","hong-kong"]

# Weather / collection
MARKETS_INTERVAL_MINUTES=15
FORECASTS_INTERVAL_MINUTES=60
OBSERVATIONS_INTERVAL_MINUTES=60
RESOLUTIONS_INTERVAL_MINUTES=30
WEEKLY_VALIDATION_ENABLED=true
WEEKLY_VALIDATION_DAY_OF_WEEK=sun
WEEKLY_VALIDATION_HOUR_UTC=18
WEEKLY_VALIDATION_MINUTE_UTC=0
VALIDATION_HISTORY_DAYS=730
VALIDATION_MIN_SAMPLES=120
BOOK_DEPTH_LEVELS=20
FORECAST_DAYS=5
ENSEMBLE_MODELS=["gfs025","ecmwf_ifs025"]
DETERMINISTIC_MODELS=["ecmwf_ifs025","gfs_seamless","icon_seamless"]
NWS_USER_AGENT=WeatherBot/0.1 (set-contact-in-env)

# Strategy and risk. Paper mode only in this phase.
BANKROLL=1000
KELLY_FRACTION=0.15
MIN_EDGE_NET=0.08
LONGSHOT_MAX_PRICE=0.20
MIN_HOURS_TO_CLOSE=2
MAX_HOURS_TO_CLOSE=72
TAKER_FEE_RATE=0.05
PROB_CLAMP_EPSILON=0.005
SPREAD_INFLATION=1
MAX_STAKE_PER_ORDER=10
MAX_EXPOSURE_PER_MARKET=50
MAX_DAILY_LOSS=25
PAPER_TRADING_ENABLED=true
PAPER_INITIAL_CASH=1000
PAPER_BOOK_STALE_SECONDS=3600

# Live readiness locks. Keep disabled until a separate explicit approval phase.
LIVE_TRADING_ENABLED=false
LIVE_BANKROLL_CAP=100
LIVE_KILL_SWITCH_ENABLED=true
LIVE_KILL_SWITCH_ENGAGED=true

# Future live credentials must stay only in .env, never in code or logs.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_WALLET_ADDRESS=
